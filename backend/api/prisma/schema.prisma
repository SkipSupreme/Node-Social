generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  password                 String // stored Argon2id hash
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String? // Email verification token
  emailVerificationExpires DateTime? // When verification token expires
  resetToken               String? // Password reset token
  resetTokenExpires        DateTime? // When reset token expires
  createdAt                DateTime  @default(now())

  // Profile Fields
  username        String    @unique @default(cuid()) // Default for migration, should be set by user
  firstName       String?
  lastName        String?
  dateOfBirth     DateTime?
  bio             String?
  avatar          String?
  bannerColor     String?   // Hex color for profile banner background
  bannerImage     String?   // URL for custom banner image
  location        String?   // User's location (e.g., "The Internet")
  website         String?   // User's website URL
  cred            Int       @default(0)
  era             String    @default("Lurker Era")
  theme           String?
  role            String    @default("user") // 'user', 'admin', 'moderator'
  nodeCredScores  Json      @default("{}") // Map<NodeId, number>
  lastActiveAt    DateTime  @default(now()) // For activity multiplier calculation

  // Relations
  posts               Post[]
  comments            Comment[]
  managedNodes        Node[]
  refreshTokens       RefreshToken[]
  federatedIdentities FederatedIdentity[] // OAuth provider identities
  feedPreference      UserFeedPreference?
  reactions           VibeReaction[] // User's Vibe Vector reactions
  pollVotes           PollVote[]
  savedPosts          SavedPost[]
  mutes               UserMute[]    @relation("UserMutes")
  mutedBy             UserMute[]    @relation("UserMutedBy")
  blocks              UserBlock[]   @relation("UserBlocks")

  blockedBy           UserBlock[]   @relation("UserBlockedBy")
  following           UserFollow[]  @relation("UserFollowing")
  followers           UserFollow[]  @relation("UserFollowers")
  credTransactions    CredTransaction[]
  notifications       Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("NotificationActor")
  
  // Messages
  sentMessages     Message[] @relation("SentMessages")
  conversations    ConversationParticipant[]

  // Customization
  customCss       String? // User's custom CSS

  // Moderation
  isModerator     Boolean @default(false)

  // Moderation Relations
  assignedModItems ModQueueItem[] @relation("ModAssignee")

  resolvedModItems ModQueueItem[] @relation("ModResolver")
  
  // Phase 5: Community
  createdPresets FeedPreset[] @relation("PresetCreator")

  // Node Subscriptions
  nodeSubscriptions NodeSubscription[]
  mutedNodes        NodeMute[]

  // Reports
  reports Report[]

  // Web of Trust (Vouching)
  vouchesGiven    Vouch[]   @relation("VouchGiver")
  vouchesReceived Vouch[]   @relation("VouchReceiver")

  // Appeals System (Node Court)
  appealsCreated  Appeal[]      @relation("AppealAppellant")
  jurorDuties     AppealJuror[] @relation("AppealJuror")
  appealVotes     AppealVote[]  @relation("AppealVoter")

  // Bot Configuration (Content Curator)
  isBot         Boolean  @default(false)
  botConfig     Json?    // { persona: "TechDigest", nodeSlug: "technology", nodeId: "..." }
  curatedNodes  Node[]   @relation("NodeCuratorBot") // Nodes this bot curates

  // Eigentrust & Web of Trust
  seedNode      SeedNode?
  trustScore    TrustScore?

  // Bicameral Governance
  governanceProposals GovernanceProposal[]
  voiceCredits        VoiceCredits[]
  councilMemberships  CouncilMember[]
}

model Notification {
  id          String   @id @default(cuid())
  userId      String   // Recipient
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId     String   // Who triggered it
  actor       User     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  type        String   // 'like', 'comment', 'follow', 'system'
  content     String?  // Optional text preview
  postId      String?  // Optional link to post
  commentId   String?  // Optional link to comment
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model CredTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  reason      String   // 'post_reaction_earned', 'post_reaction_lost', 'daily_login', 'manual_award', etc.
  sourceType  String?  // 'post', 'comment', null for system awards
  sourceId    String?  // ID of the source content
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("cred_transactions")
}

model Node {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  color       String?
  createdAt   DateTime @default(now())

  // Node Identity (Phase B)
  avatar      String?  // URL to uploaded avatar image
  banner      String?  // URL to uploaded banner image (null = use gradient from color)
  rules       Json     @default("[]")  // Array of rule strings: ["Rule 1", "Rule 2"]

  // Curation Bot
  curatorBotId String?
  curatorBot   User?    @relation("NodeCuratorBot", fields: [curatorBotId], references: [id])

  // Relations
  posts       Post[]
  creatorId   String?
  creator     User?     @relation(fields: [creatorId], references: [id])
  vibeWeights NodeVibeWeight[] // Per-node vector weightings
  reactions   VibeReaction[]   // Reactions in this Node's context
  modQueueItems ModQueueItem[]
  vectorConfig  NodeVectorConfig?
  subscriptions NodeSubscription[] // Users subscribed to this node
  muters        NodeMute[] // Users who have muted this node

  // Node Charter (governance configuration)
  charter       NodeCharter?

  @@map("nodes")
}

// Node Subscriptions - Users joining communities
model NodeSubscription {
  id        String   @id @default(uuid())
  userId    String
  nodeId    String
  role      String   @default("member") // member, moderator, admin
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([nodeId])
  @@map("node_subscriptions")
}

// Node Mutes - Users hiding nodes from their feed without leaving
model NodeMute {
  id        String   @id @default(uuid())
  userId    String
  nodeId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([userId])
  @@map("node_mutes")
}

model Post {
  id        String   @id @default(cuid())
  content   String?  // Optional for poll-only or link-only posts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  editedAt  DateTime? // Track if edited
  authorId  String
  nodeId    String?
  linkUrl   String?
  mediaUrl  String?  // Direct image/video URL (e.g., i.redd.it, preview.redd.it)
  galleryUrls String[] @default([]) // For Reddit galleries and multi-image posts
  linkMetaId String?
  title      String?
  postType   String    @default("text") // text, image, link, video
  visibility String    @default("public")
  expertGateCred Int?  // Minimum cred required to comment (null = open to all)

  // Rich text content (TipTap)
  contentJson   Json?    // TipTap/ProseMirror JSON format for rich text
  contentFormat String   @default("markdown") // "markdown" | "tiptap"

  // Content Intelligence (Tier 2)
  mediaType   String?   // "photo" | "video" | "gif" | null
  textDensity String?   // "micro" | "short" | "medium" | "long" | null
  textLength  Int?      // Character count of content

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  node      Node?    @relation(fields: [nodeId], references: [id])
  linkMeta  LinkMetadata? @relation(fields: [linkMetaId], references: [id])

  // Relations
  comments Comment[]
  metrics  PostMetric?
  reactions VibeReaction[] // Vibe Vector reactions on this post
  vibeAggregate PostVibeAggregate?
  poll     Poll?
  savedBy  SavedPost[]
  modQueueItems ModQueueItem[]

  // Indexes for feed performance
  @@index([authorId, createdAt(sort: Desc)])
  @@index([nodeId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

model Poll {
  id        String   @id @default(cuid())
  postId    String   @unique
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  question  String
  createdAt DateTime @default(now())
  endsAt    DateTime?

  options   PollOption[]
  votes     PollVote[]

  @@map("polls")
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  order     Int
  
  votes     PollVote[]

  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pollId, userId]) // One vote per user per poll
  @@map("poll_votes")
}

model LinkMetadata {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String?
  description String?
  image       String?
  domain      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@map("link_metadata")
}

model Comment {
  id        String    @id @default(uuid())
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  reactions VibeReaction[] // Vibe Vector reactions on this comment
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([postId, createdAt(sort: Desc)])
  @@index([parentId, createdAt(sort: Desc)])
  @@map("comments")
}

model PostMetric {
  postId          String   @id
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  likeCount       Int      @default(0)
  commentCount    Int      @default(0)
  shareCount      Int      @default(0)
  saveCount       Int      @default(0)
  viewCount       Int      @default(0)
  engagementScore Float    @default(0)
  qualityScore    Float    @default(50.0)
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([engagementScore(sort: Desc)])
  @@index([qualityScore(sort: Desc)])
  @@map("post_metrics")
}

enum EmailTemplate {
  VERIFICATION
  PASSWORD_RESET
}

enum EmailJobStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model EmailJob {
  id            String         @id @default(uuid())
  to            String
  template      EmailTemplate
  payload       Json
  status        EmailJobStatus @default(PENDING)
  attempts      Int            @default(0)
  maxAttempts   Int            @default(5)
  lastError     String?
  nextAttemptAt DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, nextAttemptAt])
}

// CRITICAL: Refresh Token Rotation with Reuse Detection (Token Families)
// Per document Section 3.2 - "The most critical component"
model RefreshToken {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String // Store hash, not raw token, for security
  familyId      String // The identifier for the rotation chain
  parentTokenId String? // Lineage tracking - references another RefreshToken
  parentToken   RefreshToken?  @relation("TokenFamily", fields: [parentTokenId], references: [id])
  childTokens   RefreshToken[] @relation("TokenFamily")
  expiresAt     DateTime
  revoked       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  lastUsedAt    DateTime?      // Track when token was last used for refresh

  @@index([tokenHash])
  @@index([familyId])
  @@index([userId, revoked])
  @@map("refresh_tokens")
}

// Federated Identity: Links OAuth provider IDs to internal User IDs
// Per document Section 3.1.2 - Enables many-to-one relationship (multiple providers per user)
model FederatedIdentity {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // 'google' or 'apple'
  providerSubjectId String // The OIDC 'sub' claim from the provider
  providerEmail     String? // Snapshot of email from provider (may differ from user.email)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Enforce uniqueness: One provider_subject_id per provider
  // This prevents duplicate linking and enables fast lookups
  @@unique([provider, providerSubjectId])
  @@index([provider, providerSubjectId]) // Fast lookup during login
  @@index([userId]) // Fast lookup of all providers for a user
  @@map("federated_identities")
}

// Moderation Action Log: Public immutable log of moderation actions
// Per FINAL_PLAN.md Section 5.2 - Foundation for Node Court and transparency
model ModActionLog {
  id            String   @id @default(uuid())
  moderatorId   String?  // null if automated or self-delete
  targetType    String   // 'post', 'comment', 'user'
  targetId      String
  action        String   // 'delete', 'hide', 'warn', 'ban'
  reason        String?
  metadata      Json?    // Additional context (e.g., appeal info, Node Court verdict)
  createdAt     DateTime @default(now())

  // Meta-moderation reviews of this action
  metaModTasks  MetaModerationTask[]

  @@index([targetType, targetId])
  @@index([moderatorId])
  @@index([createdAt(sort: Desc)])
  @@map("mod_action_logs")
}

// User Feed Preferences: Vibe Validator settings
// Per weighted_parameters_starter.md - Controls feed algorithm weights
// Supports 4 complexity modes: Simple (presets), Intermediate, Advanced, Expert
model UserFeedPreference {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ============================================
  // BASIC / SIMPLE MODE
  // ============================================
  // Main weights (must sum to 100)
  qualityWeight         Float @default(35.0)
  recencyWeight         Float @default(30.0)
  engagementWeight      Float @default(20.0)
  personalizationWeight Float @default(15.0)

  // Preset mode: 'latest', 'balanced', 'popular', 'expert', 'personal', 'custom'
  presetMode String? @default("balanced")

  // Legacy field (kept for backwards compatibility with existing API)
  recencyHalfLife String @default("12h") // 1h, 6h, 12h, 24h, 7d

  // ============================================
  // INTERMEDIATE MODE
  // ============================================
  // Time range filter: '1h', '6h', '24h', '7d', 'all'
  timeRange       String  @default("all")
  // Discovery rate: 0-100 (% of posts from outside your network)
  discoveryRate   Int     @default(15)
  // Filter toggles
  hideMutedWords  Boolean @default(true)
  showSeenPosts   Boolean @default(false)
  textOnly        Boolean @default(false)
  mediaOnly       Boolean @default(false)
  linksOnly       Boolean @default(false)
  hasDiscussion   Boolean @default(false)
  followingOnly   Boolean @default(false)
  minCred         Float?  // Optional minimum cred threshold

  // ============================================
  // ADVANCED MODE - Sub-signals
  // ============================================
  // Quality sub-signals (should sum to 100)
  authorCredWeight     Int @default(50)
  vectorQualityWeight  Int @default(35)
  confidenceWeight     Int @default(15)

  // Recency sub-signals (should sum to 100)
  timeDecay       Int    @default(60)
  velocity        Int    @default(25)
  freshness       Int    @default(15)
  halfLifeHours   Int    @default(12)  // 1-168 hours
  decayFunction   String @default("exponential") // 'exponential', 'linear', 'step'

  // Engagement sub-signals (should sum to 100)
  intensity           Int @default(40)
  discussionDepth     Int @default(30)
  shareWeight         Int @default(20)
  expertCommentBonus  Int @default(10)

  // Personalization sub-signals (should sum to 100)
  followingWeight Int @default(50)
  alignment       Int @default(20)
  affinity        Int @default(15)
  trustNetwork    Int @default(15)

  // Vector multipliers (JSON: { insightful: 100, joy: 100, fire: 100, ... })
  // Values 0-200, 100 = neutral, >100 = boost, <100 = suppress
  vectorMultipliers Json @default("{\"insightful\": 100, \"joy\": 100, \"fire\": 100, \"support\": 100, \"shock\": 100, \"questionable\": 100}")

  // Anti-alignment penalty (0-100): Reduce score of posts that anti-match your vibe
  antiAlignmentPenalty Int @default(20)

  // ============================================
  // EXPERT MODE
  // ============================================
  // Diversity controls
  maxPostsPerAuthor       Int @default(3)  // 1-10, max posts from same author in feed
  topicClusteringPenalty  Int @default(20) // 0-100, penalize similar topics in sequence

  // Content type ratios (targets, not hard filters) - should sum to 100
  textRatio   Int @default(40)
  imageRatio  Int @default(25)
  videoRatio  Int @default(20)
  linkRatio   Int @default(15)

  // Exploration pool: 'global', 'network', 'node'
  explorationPool String @default("global")

  // Mood toggle: 'normal', 'chill', 'intense', 'discovery'
  moodToggle String @default("normal")

  // Experimental features
  enableExperiments  Boolean @default(false)
  timeBasedProfiles  Boolean @default(false) // Auto-switch profiles by time of day

  // ============================================
  // METADATA
  // ============================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_feed_preferences")
}

// Platform-wide Vibe Vector definitions (config table)
// Phase 0.1 - Core feature: Vibe Vectors system
model VibeVector {
  id          String   @id @default(uuid())
  slug        String   @unique // "funny", "insightful", "angry", "novel", "cursed"
  name        String   // Display name: "Funny", "Insightful", etc.
  emoji       String?  // Optional emoji icon
  description String?  // Tooltip/help text
  order       Int      // Display order in radial wheel
  enabled     Boolean  @default(true) // Can disable platform-wide
  
  // Relations
  nodeWeights NodeVibeWeight[] // Which nodes weight this vector how much
  
  @@map("vibe_vectors")
}

// Per-Node weighting of vectors (how much each vector matters in that Node)
// Phase 0.1 - Node-specific vector weighting affects feed ranking
model NodeVibeWeight {
  id          String   @id @default(uuid())
  nodeId      String
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  vectorId    String
  vector      VibeVector @relation(fields: [vectorId], references: [id])
  weight      Float    @default(1.0) // 0.0-2.0+, how much this vector affects ranking in this Node
  
  @@unique([nodeId, vectorId])
  @@index([nodeId])
  @@map("node_vibe_weights")
}

// User reactions to posts/comments with intensity-based Vibe Vectors
// Phase 0.1 - Core feature: Multi-vector intensity reactions
model VibeReaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  nodeId      String   // Which Node's context (affects weighting calculation)
  node        Node     @relation(fields: [nodeId], references: [id])
  
  // Intensity-based reactions (0.0-1.0 for each vector)
  intensities Json     // {"funny": 0.8, "insightful": 0.2, "angry": 0.0, "novel": 0.0}
  totalIntensity Float @default(0.0) // Sum of all intensities
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Note: Unique constraint handled at application level since Prisma doesn't support conditional uniques
  // One reaction per user per post per node OR one reaction per user per comment per node
  @@index([postId, nodeId])
  @@index([commentId, nodeId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, postId, nodeId])
  @@index([userId, commentId, nodeId])
  @@map("vibe_reactions")
}

model PostVibeAggregate {
  postId String @id
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Sum of all intensity values per vector
  insightfulSum    Float @default(0)
  joySum           Float @default(0)
  fireSum          Float @default(0)
  supportSum       Float @default(0)
  shockSum         Float @default(0)
  questionableSum  Float @default(0)

  // Count of reactions that included each vector (intensity > 0)
  insightfulCount  Int @default(0)
  joyCount         Int @default(0)
  fireCount        Int @default(0)
  supportCount     Int @default(0)
  shockCount       Int @default(0)
  questionableCount Int @default(0)

  // Total unique reactors
  totalReactors    Int @default(0)

  // Total intensity across all vectors
  totalIntensity   Float @default(0)

  // Computed scores
  qualityScore     Float @default(0)
  engagementScore  Float @default(0)
  flagScore        Float @default(0)

  // Timestamps
  firstReactionAt  DateTime?
  lastReactionAt   DateTime?

  // Velocity tracking
  reactionsLastHour   Int @default(0)
  reactionsLast4Hours Int @default(0)

  updatedAt DateTime @updatedAt

  @@map("post_vibe_aggregates")
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@map("saved_posts")
}

model UserMute {
  id        String   @id @default(cuid())
  muterId   String
  muter     User     @relation("UserMutes", fields: [muterId], references: [id], onDelete: Cascade)
  mutedId   String
  muted     User     @relation("UserMutedBy", fields: [mutedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([muterId, mutedId])
  @@map("user_mutes")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@map("user_blocks")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("user_follows")
}

// Messaging System
model Conversation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}


// Moderation Queue
model ModQueueItem {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id])
  
  flagScore        Decimal @db.Decimal(8, 2)
  weightedFlagScore Decimal @db.Decimal(8, 2)
  priority         String  // 'critical', 'high', 'medium', 'low', 'monitor'
  
  // Breakdown
  questionableRatio Decimal? @db.Decimal(5, 4)
  shockRatio        Decimal? @db.Decimal(5, 4)
  comboRatio        Decimal? @db.Decimal(5, 4)
  velocitySpike     Decimal? @db.Decimal(8, 2)
  reportCount       Int      @default(0)
  
  // Status
  status     String   @default("pending") // 'pending', 'reviewing', 'resolved', 'escalated'
  assignedTo String?
  assignee   User?    @relation("ModAssignee", fields: [assignedTo], references: [id])
  
  // Resolution
  resolutionAction String?
  resolutionReason String?
  resolvedBy       String?
  resolver         User?    @relation("ModResolver", fields: [resolvedBy], references: [id])
  resolvedAt       DateTime?
  
  createdAt     DateTime @default(now())
  firstFlagAt   DateTime @default(now())
  lastUpdated   DateTime @default(now()) @updatedAt

  @@index([nodeId, priority, createdAt])
  @@index([assignedTo])
  @@map("mod_queue_items")
}

// User Reports
model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  String   // 'post', 'comment', 'user'
  targetId    String
  reason      String   // 'spam', 'harassment', 'hate_speech', 'misinformation', 'violence', 'other'
  details     String?  // Optional additional context
  status      String   @default("pending") // 'pending', 'reviewed', 'actioned', 'dismissed'
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([status, createdAt])
  @@map("reports")
}

// Web of Trust - Vouching System
// Per master_plan.md - Build trust through stake-based vouching
model Vouch {
  id          String   @id @default(uuid())
  voucherId   String   // User giving the vouch
  voucher     User     @relation("VouchGiver", fields: [voucherId], references: [id], onDelete: Cascade)
  voucheeId   String   // User receiving the vouch
  vouchee     User     @relation("VouchReceiver", fields: [voucheeId], references: [id], onDelete: Cascade)
  stake       Int      @default(100) // Cred staked on this vouch
  penaltyPaid Int?     // Cred lost when revoked (50% penalty)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  @@unique([voucherId, voucheeId])
  @@index([voucheeId])
  @@index([voucherId, active])
  @@map("vouches")
}

// Node Vector Customization
model NodeVectorConfig {
  nodeId String @id
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  
  vectorLabels Json @default("{\"insightful\": {\"label\": \"Insightful\", \"icon\": \"💡\"}, \"joy\": {\"label\": \"Joy\", \"icon\": \"😄\"}, \"fire\": {\"label\": \"Fire\", \"icon\": \"🔥\"}, \"support\": {\"label\": \"Support\", \"icon\": \"💙\"}, \"shock\": {\"label\": \"Shock\", \"icon\": \"😱\"}, \"questionable\": {\"label\": \"Questionable\", \"icon\": \"🤔\"}}")
  
  disabledVectors String[] @default([])
  
  // Phase 4: Expert Features
  expertConfig     Json     @default("{}")
  suppressionRules Json     @default("[]")
  boostRules       Json     @default("[]")
  
  updatedAt DateTime @default(now()) @updatedAt

  @@map("node_vector_configs")
}

// Phase 5: Community & Sharing
model FeedPreset {
  id          String   @id @default(uuid())
  name        String
  description String?
  creatorId   String
  creator     User     @relation("PresetCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  
  config      Json     // Stores FeedPreferences + ExpertConfig
  isPublic    Boolean  @default(false)
  downloads   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([isPublic, downloads(sort: Desc)])
  @@index([creatorId])
  @@map("feed_presets")
}

// Node Court - Appeals System
// Per master_plan.md - Three-tier court system with stake-based appeals
model Appeal {
  id            String   @id @default(uuid())

  // What's being appealed
  targetType    String   // 'post', 'comment', 'user_action'
  targetId      String   // ID of the target content/action
  nodeId        String?  // Node context for the appeal

  // Who's appealing
  appellantId   String
  appellant     User     @relation("AppealAppellant", fields: [appellantId], references: [id], onDelete: Cascade)

  // Appeal details
  reason        String   // Why appellant believes action was wrong
  stake         Int      // Cred staked on this appeal

  // Jury
  jurySize      Int      @default(5) // Number of jurors
  juryDeadline  DateTime // When voting ends

  // Status tracking
  status        String   @default("pending") // pending, voting, upheld, overturned, expired

  // Verdict
  verdict       String?  // 'upheld' or 'overturned'
  verdictReason String?  // Explanation of verdict
  resolvedAt    DateTime?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  votes         AppealVote[]
  jurors        AppealJuror[]

  @@index([status, createdAt])
  @@index([appellantId])
  @@index([targetType, targetId])
  @@map("appeals")
}

// Jurors assigned to an appeal
model AppealJuror {
  id        String   @id @default(uuid())
  appealId  String
  appeal    Appeal   @relation(fields: [appealId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("AppealJuror", fields: [userId], references: [id], onDelete: Cascade)

  // Juror status
  notifiedAt DateTime @default(now())
  hasVoted   Boolean  @default(false)

  @@unique([appealId, userId])
  @@index([userId, hasVoted])
  @@map("appeal_jurors")
}

// Votes cast by jurors on appeals
model AppealVote {
  id        String   @id @default(uuid())
  appealId  String
  appeal    Appeal   @relation(fields: [appealId], references: [id], onDelete: Cascade)
  jurorId   String
  juror     User     @relation("AppealVoter", fields: [jurorId], references: [id], onDelete: Cascade)

  // The vote
  vote      String   // 'uphold' or 'overturn'
  reason    String?  // Optional explanation
  weight    Float    // Cred-weighted vote power

  createdAt DateTime @default(now())

  @@unique([appealId, jurorId])
  @@index([appealId])
  @@map("appeal_votes")
}

// ============================================
// CONTENT CURATOR SYSTEM
// ============================================

// Staging area for harvested content
model CurationQueue {
  id            String   @id @default(uuid())

  // Source info
  sourceType    String   // "reddit" | "hackernews" | "bluesky" | "rss" | "youtube"
  sourceId      String   // Original post ID from source (for dedup)
  sourceUrl     String   // Link back to original
  sourceScore   Int?     // Upvotes/points from source platform
  subreddit     String?  // For Reddit: which subreddit

  // Content
  title         String
  content       String?  @db.Text // Body text or description
  linkUrl       String?  // External link if it's a link post
  mediaUrl      String?  // Image/video URL if applicable
  galleryUrls   String[] @default([]) // For Reddit galleries and multi-image posts

  // Curation
  suggestedNode String?  // Which node slug this might belong to
  aiScore       Int?     // 1-10 score from Claude
  aiReason      String?  @db.Text // Why Claude scored it this way
  status        String   @default("pending") // "pending" | "approved" | "rejected" | "posted"

  // Hybrid mode
  confidence    Float?   // How confident Claude is (0-1)
  needsReview   Boolean  @default(false)

  // Metadata
  createdAt     DateTime @default(now())
  curatedAt     DateTime?
  postedAt      DateTime?
  postedById    String?  // Which bot user posted it
  postId        String?  // Resulting Post ID if posted

  feedback      CurationFeedback[]

  @@unique([sourceType, sourceId])
  @@index([status, createdAt])
  @@index([needsReview, status])
  @@index([suggestedNode])
  @@map("curation_queue")
}

// Track pagination cursors per source
model HarvestCursor {
  id          String   @id @default(uuid())
  sourceType  String   @unique // "reddit:r/technology" | "hackernews" | etc
  lastSeenId  String?  // Last item ID we processed
  lastRunAt   DateTime @default(now())
  metadata    Json?    // Additional cursor data (e.g., after tokens)

  @@map("harvest_cursors")
}

// Track Q's feedback for learning
model CurationFeedback {
  id            String   @id @default(uuid())
  queueItemId   String
  queueItem     CurationQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  decision      String   // "approved" | "rejected"
  reason        String?  // "clickbait" | "boring" | "wrong-node" | "duplicate" | "valuable"
  createdAt     DateTime @default(now())

  @@index([queueItemId])
  @@index([createdAt])
  @@map("curation_feedback")
}

// ============================================
// EIGENTRUST & WEB OF TRUST SYSTEM
// Per governance.md Section 3 - Trust-Weighted Exploration Engine
// ============================================

// Seed Nodes - Pre-trusted peers that anchor the trust graph
// Per governance.md Section 3.1.2: "Founding Nodes" anchor Eigentrust
model SeedNode {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?  // Why this user is a seed node
  addedBy   String?  // Admin who added them
  addedAt   DateTime @default(now())
  active    Boolean  @default(true)

  @@map("seed_nodes")
}

// Global Trust Scores - Computed via Eigentrust algorithm
// Per governance.md Section 3.1: Transitive trust via random walk
model TrustScore {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Raw Eigentrust score (0.0 to 1.0)
  rawScore      Float    @default(0)

  // Decayed score after applying time-based decay
  // Per governance.md Section 3.3: Trust_current = Trust_raw × e^(-λt)
  decayedScore  Float    @default(0)

  // Trust tier derived from decayed score percentile
  // Per governance.md Section 3.1.2: Gold/Silver/Bronze/Shadow
  tier          String   @default("shadow") // "gold", "silver", "bronze", "shadow"

  // Distance from nearest seed node (for display)
  seedDistance  Int?

  // When the score was last computed
  computedAt    DateTime @default(now())

  // User's last activity (for decay calculation)
  lastActiveAt  DateTime @default(now())

  @@index([tier])
  @@index([decayedScore(sort: Desc)])
  @@map("trust_scores")
}

// Trust Matrix Edges - Direct trust relationships
// This augments Vouch with computed trust values
model TrustEdge {
  id          String   @id @default(uuid())

  // Trust direction: from -> to
  fromUserId  String
  toUserId    String

  // Normalized direct trust (0.0 to 1.0)
  // Sum of all outgoing edges from a user should = 1.0
  directTrust Float

  // Source of trust (vouch, positive_reactions, etc.)
  source      String   @default("vouch")

  // Weight before normalization
  rawWeight   Float    @default(1.0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("trust_edges")
}

// Trust Computation Log - Track algorithm runs
model TrustComputationLog {
  id              String   @id @default(uuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  status          String   @default("running") // "running", "completed", "failed"
  usersProcessed  Int      @default(0)
  edgesProcessed  Int      @default(0)
  iterations      Int      @default(0)
  convergenceDelta Float?
  error           String?

  @@index([startedAt(sort: Desc)])
  @@map("trust_computation_logs")
}

// ============================================
// NODE CHARTER SYSTEM
// Per governance.md Section 4.2 - Smart Contract Governance
// "The Node Charter is not just text; it is a configuration file"
// ============================================

model NodeCharter {
  id        String   @id @default(uuid())
  nodeId    String   @unique
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  // Governance Style (per Section 4.1.2)
  governanceStyle String @default("republic") // "dictatorship", "republic", "democracy"

  // Mod Term Limits (per Section 4.2, 7.3)
  modTermLengthDays     Int      @default(180) // 6 months default
  modTermsAllowed       Int      @default(3)   // Max consecutive terms
  incumbencyThreshold   Float    @default(0.55) // 55% for 2nd term, increases per term

  // Ban Appeal Process (per Section 6.3)
  banAppealThresholdHours Int    @default(24) // Bans > this go to Node Jury
  autoAppealEnabled       Boolean @default(true)

  // Exploration Rate (per Section 5.3)
  explorationRate       Float    @default(0.10) // 10% of feed must be from non-members

  // Content Moderation Settings
  autoModLevel          String   @default("medium") // "low", "medium", "high"
  requireCitations      Boolean  @default(false)
  minTrustToPost        String   @default("shadow") // Minimum tier to post

  // Voting Rules
  quorumPercent         Float    @default(0.10) // 10% of active members for valid vote
  supermajorityPercent  Float    @default(0.67) // 67% for major changes

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Track charter amendments
  amendments  CharterAmendment[]

  @@map("node_charters")
}

model CharterAmendment {
  id          String   @id @default(uuid())
  charterId   String
  charter     NodeCharter @relation(fields: [charterId], references: [id], onDelete: Cascade)

  field       String   // Which field was changed
  oldValue    String   // Previous value (JSON encoded)
  newValue    String   // New value (JSON encoded)
  reason      String?  // Why the change was made
  proposedBy  String   // User ID who proposed
  approvedAt  DateTime @default(now())

  @@index([charterId])
  @@map("charter_amendments")
}

// ============================================
// META-MODERATION SYSTEM
// Per governance.md Section 8.2 - Slashdot's Meta-Moderation
// "Random sample of high-trust users asked: Was this moderation fair?"
// ============================================

model MetaModerationTask {
  id              String   @id @default(uuid())

  // The moderation action being reviewed
  modActionId     String
  modAction       ModActionLog @relation(fields: [modActionId], references: [id], onDelete: Cascade)

  // The moderator whose action is being reviewed
  moderatorId     String

  // Sampling metadata
  createdAt       DateTime @default(now())
  expiresAt       DateTime // Deadline for meta-mods to vote
  status          String   @default("pending") // "pending", "completed", "expired"

  // Aggregated results
  fairVotes       Int      @default(0)
  unfairVotes     Int      @default(0)
  biasVotes       Int      @default(0)
  overreactionVotes Int    @default(0)

  // Final verdict
  verdict         String?  // "fair", "unfair", "bias", "overreaction"
  verdictAt       DateTime?

  // Impact on moderator
  modTrustImpact  Float?   // How much trust the mod gained/lost

  // Individual votes
  votes           MetaModVote[]

  @@index([moderatorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("meta_moderation_tasks")
}

model MetaModVote {
  id          String   @id @default(uuid())
  taskId      String
  task        MetaModerationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  voterId     String
  vote        String   // "fair", "unfair", "bias", "overreaction"
  votedAt     DateTime @default(now())

  @@unique([taskId, voterId])
  @@index([taskId])
  @@map("meta_mod_votes")
}

// ============================================
// BICAMERAL GOVERNANCE SYSTEM
// Per governance.md Section 7.1 - Optimism-style Bicameral Governance
// House 1: Vibe Council (Commons) - one-person-one-vote
// House 2: Node Senate (Lords) - weighted by Trust + Quadratic Voting
// ============================================

model GovernanceProposal {
  id            String   @id @default(uuid())

  title         String
  description   String
  proposerId    String
  proposer      User     @relation(fields: [proposerId], references: [id])

  // Proposal type determines which house(s) must approve
  proposalType  String   // "feature", "policy", "protocol", "emergency"

  // For protocol changes, both houses must approve
  requiresBothHouses Boolean @default(false)

  // Voting period
  createdAt     DateTime @default(now())
  votingStartsAt DateTime
  votingEndsAt   DateTime

  // Status
  status        String   @default("draft") // "draft", "voting", "passed", "rejected", "vetoed"

  // Vote tallies
  vibeCouncilYes    Int @default(0)
  vibeCouncilNo     Int @default(0)
  vibeCouncilQuorum Int @default(0) // Required for validity
  vibeCouncilPassed Boolean?

  nodeSenateYes     Float @default(0) // Weighted votes
  nodeSenateNo      Float @default(0)
  nodeSenateQuorum  Float @default(0)
  nodeSenatePassed  Boolean?

  // Individual votes
  votes         GovernanceVote[]

  @@index([status])
  @@index([votingEndsAt])
  @@map("governance_proposals")
}

model GovernanceVote {
  id          String   @id @default(uuid())
  proposalId  String
  proposal    GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  voterId     String

  // Which house they're voting in
  house       String   // "vibe_council" or "node_senate"

  // Vote direction
  vote        String   // "yes", "no", "abstain"

  // For quadratic voting in Senate
  voiceCreditsSpent Int @default(1)
  voteWeight        Float @default(1) // sqrt(credits) for QV

  votedAt     DateTime @default(now())

  @@unique([proposalId, voterId, house])
  @@index([proposalId])
  @@map("governance_votes")
}

// Voice Credits for Quadratic Voting
// Per governance.md Section 7.2
model VoiceCredits {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Credits allocated per cycle
  cycleStart  DateTime
  cycleEnd    DateTime
  allocated   Int      @default(100) // 100 credits per cycle
  spent       Int      @default(0)
  remaining   Int      @default(100)

  @@unique([userId, cycleStart])
  @@index([userId])
  @@map("voice_credits")
}

// Council Membership
// Per governance.md Section 7.1, 7.3
model CouncilMember {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  house       String   // "vibe_council" or "node_senate"

  // Election details
  electedAt   DateTime
  termEndsAt  DateTime
  termNumber  Int      @default(1) // Which consecutive term

  // Status
  active      Boolean  @default(true)
  recalledAt  DateTime?

  // For Node Senate: which node they represent
  representingNodeId String?

  @@unique([userId, house])
  @@index([house, active])
  @@map("council_members")
}

// Recall Petitions
// Per governance.md Section 7.3
model RecallPetition {
  id            String   @id @default(uuid())
  targetUserId  String   // Council member being recalled
  house         String   // Which house

  reason        String
  initiatedBy   String   // User who started petition
  createdAt     DateTime @default(now())

  // Signature collection
  signaturesRequired Int    // 10% of active electorate
  signaturesCollected Int   @default(0)
  status        String   @default("collecting") // "collecting", "triggered", "failed", "recalled"

  // If triggered, the snap election
  electionTriggeredAt DateTime?

  signatures    RecallSignature[]

  @@index([targetUserId])
  @@index([status])
  @@map("recall_petitions")
}

model RecallSignature {
  id          String   @id @default(uuid())
  petitionId  String
  petition    RecallPetition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  signerId    String
  signedAt    DateTime @default(now())

  // Trust-weighted signature value
  signatureWeight Float @default(1)

  @@unique([petitionId, signerId])
  @@index([petitionId])
  @@map("recall_signatures")
}

// ============================================
// EXPLORATION TAX ENFORCEMENT
// Per governance.md Section 5.3 - Protocol-level discovery
// ============================================

model ExplorationSlot {
  id          String   @id @default(uuid())
  userId      String   // User who received this exploration content

  postId      String   // The probationary content shown
  nodeId      String   // The node context

  // When it was shown
  shownAt     DateTime @default(now())

  // User interaction (feedback loop)
  interacted  Boolean  @default(false)
  interactionType String? // "view", "react", "comment", "follow"
  interactedAt DateTime?

  // Trust impact (if user engaged with exploration content)
  trustBoostApplied Boolean @default(false)
  trustBoostAmount  Float?

  @@index([userId, shownAt(sort: Desc)])
  @@index([postId])
  @@map("exploration_slots")
}

// ============================================
// USER FEED TRACKING
// ============================================

// Track posts the user has viewed (for "hide seen posts" feature)
model UserPostView {
  id          String   @id @default(uuid())
  userId      String
  postId      String
  viewedAt    DateTime @default(now())
  dwellTimeMs Int?     // How long user spent viewing
  scrollDepth Float?   // 0-1, how far they scrolled

  @@unique([userId, postId])
  @@index([userId, viewedAt(sort: Desc)])
  @@map("user_post_views")
}

// User muted words for feed filtering
model UserMutedWord {
  id        String   @id @default(uuid())
  userId    String
  word      String
  isRegex   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, word])
  @@index([userId])
  @@map("user_muted_words")
}
